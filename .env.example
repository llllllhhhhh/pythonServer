APP_NAME=学徒行 API
ENVIRONMENT=production
API_PREFIX=/api/v1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=xuetuxing
MYSQL_PASSWORD=请填写数据库密码
MYSQL_DATABASE=xuetuxing

REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0

CORS_ORIGINS=http://localhost:5178,http://127.0.0.1:5178,http://113.44.149.128,https://goxuetuxing.com,https://www.goxuetuxing.com
UPLOAD_DIR=uploads

# 上传存储：local=服务器本地 uploads 目录；obs=华为云 OBS
STORAGE_DRIVER=obs
OBS_ACCESS_KEY=请填写华为云OBS Access Key Id
OBS_SECRET_KEY=请填写华为云OBS Secret Access Key
OBS_BUCKET=xuetuxing
OBS_REGION=cn-north-4
OBS_ENDPOINT=obs.cn-north-4.myhuaweicloud.com
OBS_PUBLIC_BASE_URL=https://xuetuxing.obs.cn-north-4.myhuaweicloud.com

DEFAULT_ADMIN_PHONE=13800000000
DEFAULT_ADMIN_PASSWORD=admin123456
